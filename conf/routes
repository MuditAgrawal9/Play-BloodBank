GET     /test-ebean                 controllers.TestController.testEbean()
GET     /test-donor                 controllers.TestController.createDonor()
GET     /view-donor                 controllers.TestController.viewDonor()
GET     /seed-inventory             controllers.TestController.seedInventory()
GET     /test-request               controllers.TestController.createRequest()

#Client based routing endpoints
#Auth
POST    /api/signup                 controllers.AuthController.signup(request: Request)

POST    /api/login                  controllers.AuthController.login(request: Request)

#Admin
GET     /api/admin/stats            controllers.AdminController.getStats()

GET     /api/admin/inventory              controllers.AdminController.getInventory()

GET     /api/admin/transactions              controllers.AdminController.getTransactions()

POST    /api/transaction/:id/approve    controllers.AdminController.approve(id: Long)
POST    /api/transaction/:id/reject     controllers.AdminController.reject(id: Long)

POST    /api/admin/donation             controllers.AdminController.recordDonation(request: Request)

GET     /api/admin/donors                 controllers.AdminController.getDonors()

GET     /api/admin/users                 controllers.AdminController.getUsers()

GET     /api/admin/hospitals                 controllers.AdminController.getHospitals()

#donor
GET     /api/donor/profile            controllers.DonorController.profile(request: Request)

PUT     /api/donor/profile           controllers.DonorController.updateProfile(request: Request)

GET     /api/donor/donationHistory       controllers.DonorController.donationHistory(request: Request)

#Hospital
GET     /api/hospital/profile           controllers.HospitalController.profile(request: Request)

PUT     /api/hospital/profile          controllers.HospitalController.updateProfile(request: Request)

POST    /api/hospital/request           controllers.HospitalController.createRequest(request: Request)

GET     /api/hospital/requests          controllers.HospitalController.getRequests(request: Request)
# Map static resources from the /public folder to the /assets URL path
GET     /assets/*file               controllers.Assets.versioned(path="/public", file: Asset)

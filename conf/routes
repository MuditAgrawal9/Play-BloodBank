# Routes
# This file defines all application routes (Higher priority routes first)
# ~~~~

# An example controller showing a sample home page
#GET     /                           controllers.HomeController.index()
GET     /                           controllers.AuthController.dashboard(request: Request)


GET     /test-ebean                 controllers.TestController.testEbean()
GET     /test-donor                 controllers.TestController.createDonor()
GET     /view-donor                 controllers.TestController.viewDonor()
GET     /seed-inventory             controllers.TestController.seedInventory()
GET     /test-request               controllers.TestController.createRequest()

GET     /signup                     controllers.AuthController.signupPage()
POST    /signup                     controllers.AuthController.signup(request : Request)

GET     /login                      controllers.AuthController.loginPage()
POST    /login                      controllers.AuthController.login(request: Request)

GET     /profile                    controllers.DonorController.profile(request: Request)
POST    /profile                    controllers.DonorController.saveProfile(request: Request)

GET     /request                    controllers.RequestController.requestPage(request: Request)
POST    /request                    controllers.RequestController.submitRequest(request: Request)

GET     /my-requests                controllers.RequestController.myRequests(request: Request)


# Map static resources from the /public folder to the /assets URL path
GET     /assets/*file               controllers.Assets.versioned(path="/public", file: Asset)
